body {
  font-family: Arial, sans-serif;
  text-align: center;
  background: #f0f8ff;
}

h1 {
  color: #2c3e50;
}

#question {
  font-size: 20px;
  margin: 15px;
}

input {
  padding: 8px;
  font-size: 16px;
  width: 100px;
}

button {
  padding: 8px 15px;
  font-size: 16px;
  background: #3498db;
  color: white;
  border: none;
  cursor: pointer;
}

button:hover {
  background: #2980b9;
}

#result {
  margin-top: 10px;
  font-weight: bold;
}
